# Question 4:
# Alice, Bob and Carol pool their Halloween candy and split it evenly.
# Any leftover candies will be smashed.
# Example: If they bring home 91 candies, they'll take 30 each and smash 1.

# Variables representing the number of candies collected
alice_candies = 121
bob_candies = 77
carol_candies = 109

# Total candies collected
total_candies = alice_candies + bob_candies + carol_candies

# Candies to smash = remainder when divided by 3
to_smash = total_candies % 3

print("Total Candies:", total_candies)
print("Candies to Smash:", to_smash)  # Expected output: 1
